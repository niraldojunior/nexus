# Create a copy of this file and rename it to ./env/env.local

# Application
APP_NAME=ms-resource-catalog
APP_HOST=https://ms-resource-catalog-dev.apps.ocparc-nprd.vtal.intra
DEBUG=true
NODE_ENV=local
PORT=3000
API_ROUTE_PREFIX=api
CORS_ALLOWED_ORIGINS=*
SWAGGER_ENABLED=true
SWAGGER_ALLOWED_METHODS=
SWAGGER_API_SERVER=
SWAGGER_DESCRIPTION='Resource Catalog API is one of Catalog Management API Family. Resource Catalog API goal is to provide a catalog of resources.'

# DataDog
DD_ENABLED=false
DD_ENV=dev
DD_SERVICE=ms-resource-catalog
DD_VERSION=1.0.0

# Logs
# logstash|terminal|raw
LOG_TYPE=terminal
LOG_LEVEL=trace
LOG_LEVEL_FILE=error
LOG_LEVEL_LOGSTASH=info
LOG_LEVEL_TERMINAL=trace
LOG_LEVEL_RAW=warn
# Enable/Disable logs to file (log.txt)
LOG_CONFIG_FILE=false
# Enable/Disable logs to terminal/raw
LOG_CONFIG_TERMINAL=false
# Enable/Disable nanoseconds timestamp in logs (grants more precision)
LOG_CONFIG_NANOSECONDS=true

# ELK
LOGSTASH_HOST=qelkqx01.elk.intra
LOGSTASH_PORT=5044
LOGSTASH_INDEX=api-ms-resource-catalog-dev
LOGSTASH_SERVICE_PREFIX=ResourceCatalogManagement
LOGSTASH_RECOVERY=false
LOGSTASH_RECOVERY_QUEUE_MAX_SIZE=1024

# DB
DATABASE_TYPE=memory # oracle|mongodb|sqlite|memory

# MongoDB
MONGODB_HOST=rctlqx01.local
MONGODB_PORT=27020
MONGODB_NAME=catalogdev
MONGODB_USER=catalogdev
MONGODB_PASS=dDNtcG9yNHJpNCExOV84MDgyNA==
MONGODB_AUTH_SOURCE=admin

# Cache
CACHE_TYPE=memory # memory|redis
CACHE_TTL=3600000 # in milliseconds
CACHE_LIMIT=5000
CACHE_PREFIX=ms-resource-catalog
REDIS_SECONDARY_STORE=false

# Redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Message Broker
RMQ_HOST=amqp://guest:guest@localhost:5672
RMQ_EXCHANGE=ms-resource-catalog-x
RMQ_DEAD_LETTER_EXCHANGE=ms-resource-catalog-dlx
RMQ_DELAYED_EXCHANGE=false
RMQ_RETRY_DELAY=2000
RMQ_RETRY_COUNT=3
RMQ_PREFETCH_COUNT=2

# Portal Backend Guard
PORTAL_BACKEND_GUARD_ENABLED=false
PORTAL_BACKEND_GUARD_JWT=a1b2c3d4e5f678901234567890abcdef1234567890abcdef

# JWT
INTEGRATION_JWT_ENABLED=true

# TI
JWT_PASSWORD=Integr@cao
JWT_ID=YnNvYXF4MDU=
JWT_LOGIN=barramentosoa
JWT_SIGNATURE=c29hOlNPQCNpbmZyYUNP

# TRG2/TRG
# JWT_SIGNATURE=bTlFenVaVHF0Tld5QklzYnJESkY2MXpjZUBja2FtdTE=
# JWT_LOGIN=backmstrg
# JWT_PASSWORD='KoG59zsBqfdNdpsGlzp#0354'
# JWT_ID=and0bXN0cmc=

# Apigee
INTEGRATION_APIGEE_OAUTH_ENABLED=false
APIGEE_OAUTH_TOKEN_USERNAME=
APIGEE_OAUTH_TOKEN_PASSWORD=
APIGEE_OAUTH_TOKEN_GRANT_TYPE=client_credentials
APIGEE_OAUTH_TOKEN_SCOPE=
APIGEE_OAUTH_TOKEN_CACHE_TTL=86340000

# Secret Manager
SECRET_MANAGER_ENABLED=false
SECRET_MANAGER_AUTHENTICATOR=authn
SECRET_MANAGER_ACCOUNT=vtal
SECRET_MANAGER_LOGIN=
SECRET_MANAGER_BODY=
SECRET_MANAGER_IDENTIFIER=
SECRET_MANAGER_AUTH_CACHE_TTL=420000
SECRET_MANAGER_VARIABLE_CACHE_TTL=86400000

# Integrations
INTEGRATION_SECRET_MANAGER_URL=https://conjsm.vtal.intra
INTEGRATION_APIGEE_ENABLED=true
INTEGRATION_APIGEE_URI=https://apilocaldev2.vtal.intra

# TMF634 Resource Catalog Module
MODULE_TMF634_RESOURCE_CATALOG=true
TMF634_IN_MEMORY_SEED_ENABLED=false
TMF634_IN_MEMORY_SEED_CATALOG_COUNT=200
TMF634_IN_MEMORY_SEED_CATEGORY_COUNT=200
TMF634_IN_MEMORY_SEED_SPECIFICATION_COUNT=360

# Notification Dispatcher Module
MODULE_NOTIFICATION_DISPATCHER=true
RMQ_QUEUE_NOTIFICATION_DISPATCHER_EVENT=Q_Notification_Dispatcher
RMQ_DLQ_MSG_TTL_NOTIFICATION_DISPATCHER_EVENT=604800000
RMQ_DLQ_MAX_LENGTH_NOTIFICATION_DISPATCHER_EVENT=1000
