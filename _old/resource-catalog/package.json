{
    "name": "ms-resource-catalog",
    "version": "1.0.0",
    "description": "MS Resource Catalog (TMF 634)",
    "author": "V.tal",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --check --ignore-path .gitignore \"{src,test}/**/*.ts\"",
        "format:fix": "prettier --write --ignore-path .gitignore \"{src,test}/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --debug --watch",
        "start:prod": "node --enable-source-maps --use-openssl-ca dist/src/main",
        "lint": "eslint \"{src,test}/**/*.ts\"",
        "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --verbose",
        "test:watch": " jest --watch --verbose",
        "test:coverage": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "documentation": "npx @compodoc/compodoc -p tsconfig.json -s",
        "prepare": "husky"
    },
    "dependencies": {
        "@fastify/helmet": "13.0.2",
        "@fastify/static": "9.0.0",
        "@keyv/redis": "5.1.6",
        "@keyv/sqlite": "4.0.8",
        "@nestjs/axios": "4.0.1",
        "@nestjs/cache-manager": "3.1.0",
        "@nestjs/cli": "11.0.16",
        "@nestjs/common": "11.1.17",
        "@nestjs/config": "4.0.3",
        "@nestjs/core": "11.1.16",
        "@nestjs/event-emitter": "3.0.1",
        "@nestjs/jwt": "11.0.2",
        "@nestjs/microservices": "11.1.16",
        "@nestjs/platform-fastify": "11.1.17",
        "@nestjs/schedule": "6.1.1",
        "@nestjs/swagger": "11.2.6",
        "@nestjs/terminus": "11.1.1",
        "@nestjs/typeorm": "11.0.0",
        "amqp-connection-manager": "5.0.0",
        "amqplib": "0.10.9",
        "cache-manager": "7.2.8",
        "cacheable": "2.3.3",
        "class-transformer": "0.5.1",
        "class-validator": "0.15.1",
        "dd-trace": "5.89.0",
        "diff": "8.0.3",
        "fast-xml-parser": "5.5.9",
        "handlebars": "4.7.9",
        "husky": "9.1.7",
        "lz-string": "1.5.0",
        "mongodb": "6.21.0",
        "nestjs-cls": "6.2.0",
        "nestjs-pino": "4.6.0",
        "oracledb": "6.10.0",
        "pino": "10.3.1",
        "pino-socket": "8.0.0",
        "prettier": "3.8.1",
        "reflect-metadata": "0.2.2",
        "rxjs": "7.8.2",
        "snowflake-uuid": "1.0.0",
        "typeorm": "0.3.28"
    },
    "devDependencies": {
        "@eslint/js": "9.39.4",
        "@faker-js/faker": "10.3.0",
        "@nestjs/schematics": "11.0.9",
        "@nestjs/testing": "11.1.16",
        "@types/jest": "30.0.0",
        "@types/node": "25.4.0",
        "@types/supertest": "7.2.0",
        "@typescript-eslint/eslint-plugin": "8.57.0",
        "@typescript-eslint/parser": "8.57.0",
        "eslint": "9.39.4",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-custom": "file:resources/eslint",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-simple-import-sort": "12.1.1",
        "globals": "17.4.0",
        "jest": "30.3.0",
        "pino-pretty": "13.1.3",
        "supertest": "7.2.2",
        "ts-jest": "29.4.6",
        "ts-loader": "9.5.4",
        "ts-node": "10.9.2",
        "tsconfig-paths": "4.2.0",
        "typescript": "5.9.3",
        "typescript-eslint": "8.57.0"
    }
}
