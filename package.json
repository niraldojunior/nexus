{
  "name": "v-tal-nexus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "V.tal Nexus foundation service",
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "npm run dev:local",
    "dev:backend": "npm run dev:neon",
    "web:dev": "vite --config web/vite.config.mjs",
    "web:build": "vite build --config web/vite.config.mjs",
    "dev:neon": "npm run build && node scripts/dev-neon.mjs",
    "start:neon": "npm run build && node scripts/dev-neon.mjs --start-only",
    "dev:local": "powershell -ExecutionPolicy Bypass -File start-dev.ps1",
    "migrate:neon": "npm run build && node dist/src/scripts/migrate-sqlite-to-neon.js",
    "mcp:tmf": "npm run build && node dist/src/modules/mcp/stdio-server.js",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "node scripts/web-server.mjs",
    "test": "npm run test:unit && npm run test:integration && npm run test:regression",
    "pretest:integration": "npm run build",
    "test:unit": "node --use-system-ca node_modules/vitest/vitest.mjs run --pool threads --config vitest.config.ts",
    "test:integration": "node scripts/run-tests.mjs",
    "test:system": "npm run test:regression",
    "test:regression": "playwright test --config playwright.config.ts",
    "browsers:install": "playwright install chromium",
    "test:coverage": "vitest run --pool threads --config vitest.config.ts --coverage",
    "test:coverage:integration": "npm run build && c8 --exclude=dist/test/** --exclude=dist/scripts/** --exclude=test/** --exclude=scripts/** --reporter=text --reporter=lcov node scripts/run-tests.mjs",
    "test:watch": "vitest --pool threads --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.20.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.292.0",
    "pg": "^8.22.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/forms": "^0.5.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.1.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.16",
    "c8": "^11.0.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.3.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "^8.4.31",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.37.0",
    "vite": "npm:rolldown-vite@7.3.1",
    "vitest": "^4.1.10"
  }
}
