### -----------------------------------------------------------------
### Fase 02 - ResourceCategory (Implementado)
### -----------------------------------------------------------------

### @name tmf634ResourceCategoryCreateV2
POST {{tmfBaseUrl}}/resourceCategory
Content-Type: application/json

{
	"name": "ONT GPON",
	"description": "Categoria para equipamentos ONT",
	"lifecycleStatus": "Active",
	"category": "ONT",
	"version": "1.0.0",
	"validFor": {
		"startDateTime": "2026-03-11T00:00:00Z"
	},
	"@type": "ResourceCategory"
}

### @name tmf634ResourceCategoryListV2
GET {{tmfBaseUrl}}/resourceCategory?offset=0&limit=20&fields=id,name,lifecycleStatus
Content-Type: application/json

### @name tmf634ResourceCategoryGetByIdV2
@resourceCategoryId=category-001
GET {{tmfBaseUrl}}/resourceCategory/{{resourceCategoryId}}?fields=id,name,description
Content-Type: application/json

### @name tmf634ResourceCategoryPatchV2
PATCH {{tmfBaseUrl}}/resourceCategory/{{resourceCategoryId}}
Content-Type: application/json

{
	"description": "Categoria para ONT e equipamentos residenciais",
	"validFor": {
		"startDateTime": "2026-03-12T00:00:00Z"
	}
}

