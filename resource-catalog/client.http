### -----------------------------------------------------------------
### Fase 04 - ResourceSpecification Base (Implementado)
### -----------------------------------------------------------------

### @name tmf634ResourceSpecificationCreateV4
POST {{tmfBaseUrl}}/resourceSpecification
Content-Type: application/json

{
	"name": "CPE ZTE F670L",
	"description": "Especificacao tecnica base do equipamento",
	"lifecycleStatus": "Active",
	"version": "1.0.0",
	"resourceCategory": [
		{
			"id": "router",
			"name": "Roteador"
		}
	],
	"resourceSpecCharacteristic": [
		{
			"name": "Brand",
			"valueType": "string",
			"value": "ZTE"
		}
	],
	"validFor": {
		"startDateTime": "2026-03-11T00:00:00Z"
	},
	"@type": "ResourceSpecification"
}

### @name tmf634ResourceSpecificationListV4
GET {{tmfBaseUrl}}/resourceSpecification?offset=0&limit=20&fields=id,name,lastUpdate&validAt=2026-03-11T00:00:00Z
Content-Type: application/json

### @name tmf634ResourceSpecificationListLegacyV4
GET {{tmfBaseUrl}}/resourceEspecification?offset=0&limit=20
Content-Type: application/json

### @name tmf634ResourceSpecificationGetByIdV4
@resourceSpecificationId=spec-001
GET {{tmfBaseUrl}}/resourceSpecification/{{resourceSpecificationId}}?fields=id,name,resourceSpecCharacteristic,lastUpdate
Content-Type: application/json

### @name tmf634ResourceSpecificationGetByIdLegacyV4
GET {{tmfBaseUrl}}/resourceEspecification/{{resourceSpecificationId}}?fields=id,name
Content-Type: application/json

### @name tmf634ResourceSpecificationPatchV4
PATCH {{tmfBaseUrl}}/resourceSpecification/{{resourceSpecificationId}}
Content-Type: application/json

{
	"description": "Especificacao base atualizada",
	"resourceSpecCharacteristic": [
		{
			"name": "Model",
			"valueType": "string",
			"value": "F670L"
		}
	]
}

### -----------------------------------------------------------------
### Fase 05 - Regras Corporativas de ResourceSpecification
### -----------------------------------------------------------------

### @name tmf634ResourceSpecificationCreateFullV5
### Criacao completa com estrutura minima obrigatoria (deve retornar 201)
POST {{tmfBaseUrl}}/resourceSpecification
Content-Type: application/json

{
	"name": "CPE ZTE F670L Porte P",
	"description": "Equipamento ZTE F670L Porte pequeno",
	"lifecycleStatus": "Active",
	"version": "1.0.0",
	"resourceCategory": [
		{
			"id": "router",
			"name": "Roteador"
		}
	],
	"resourceSpecCharacteristic": [
		{ "name": "Brand", "valueType": "string", "value": "ZTE" },
		{ "name": "Model", "valueType": "string", "value": "F670L" },
		{ "name": "categoria", "valueType": "string", "value": "P" }
	],
	"validFor": {
		"startDateTime": "2026-03-11T00:00:00Z"
	},
	"@type": "ResourceSpecification"
}

### @name tmf634ResourceSpecificationCreateMissingStructureV5
### Faltando campos obrigatorios - deve retornar 400
POST {{tmfBaseUrl}}/resourceSpecification
Content-Type: application/json

{
	"name": "CPE Incompleto",
	"lifecycleStatus": "Active"
}

### @name tmf634ResourceSpecificationCreateDuplicateV5
### Segunda criacao com mesma chave corporativa - deve retornar 409
POST {{tmfBaseUrl}}/resourceSpecification
Content-Type: application/json

{
	"name": "CPE ZTE F670L Porte M (duplicado STD)",
	"lifecycleStatus": "Active",
	"resourceCategory": [
		{
			"id": "router",
			"name": "Roteador"
		}
	],
	"resourceSpecCharacteristic": [
		{ "name": "Brand", "valueType": "string", "value": "ZTE" },
		{ "name": "Model", "valueType": "string", "value": "F670L" },
		{ "name": "categoria", "valueType": "string", "value": "M" }
	],
	"validFor": {
		"startDateTime": "2026-03-11T00:00:00Z"
	}
}

### @name tmf634ResourceSpecificationCreateCustomV5
### CUSTOMIZADO coexiste com STD - uniqueKey diferente - deve retornar 201
POST {{tmfBaseUrl}}/resourceSpecification
Content-Type: application/json

{
	"name": "CPE ZTE F670L Porte CUSTOMIZADO",
	"description": "Versao customizada do equipamento",
	"lifecycleStatus": "Active",
	"resourceCategory": [
		{
			"id": "router",
			"name": "Roteador"
		}
	],
	"resourceSpecCharacteristic": [
		{ "name": "Brand", "valueType": "string", "value": "ZTE" },
		{ "name": "Model", "valueType": "string", "value": "F670L" },
		{ "name": "categoria", "valueType": "string", "value": "CUSTOMIZADO" }
	],
	"validFor": {
		"startDateTime": "2026-03-11T00:00:00Z"
	}
}

### @name tmf634ResourceSpecificationPatchConflictV5
### Patch que gera conflito de uniqueKey - deve retornar 409
@resourceSpecificationId=spec-001
PATCH {{tmfBaseUrl}}/resourceSpecification/{{resourceSpecificationId}}
Content-Type: application/json

{
	"resourceSpecCharacteristic": [
		{ "name": "Brand", "value": "Huawei" },
		{ "name": "Model", "value": "F670L" },
		{ "name": "categoria", "value": "P" }
	]
}

### @name tmf634ResourceSpecificationListByStatusV5
GET {{tmfBaseUrl}}/resourceSpecification?lifecycleStatus=Active&offset=0&limit=20
Content-Type: application/json

### @name tmf634ResourceSpecificationListByValidAtV5
GET {{tmfBaseUrl}}/resourceSpecification?validAt=2026-06-01T00:00:00Z&offset=0&limit=20
Content-Type: application/json

### -----------------------------------------------------------------
### Fase 06 - Hub e Notificacoes de Eventos
### -----------------------------------------------------------------

### @name tmf634HubCreateV6
POST {{tmfBaseUrl}}/hub
Content-Type: application/json

{
	"callback": "http://localhost:3001/listener/tmf634",
	"event": "ResourceSpecificationCreateEvent"
}

### @name tmf634HubDeleteV6
@hubId=hub-001
DELETE {{tmfBaseUrl}}/hub/{{hubId}}
Content-Type: application/json

### @name tmf634ResourceSpecificationCreateTriggerEventV6
### Deve gerar ResourceSpecificationCreateEvent para subscribers ativos
POST {{tmfBaseUrl}}/resourceSpecification
Content-Type: application/json

{
	"name": "CPE FiberHome AN5506-04",
	"lifecycleStatus": "Active",
	"resourceCategory": [
		{
			"id": "ont"
		}
	],
	"resourceSpecCharacteristic": [
		{ "name": "Brand", "value": "FiberHome" },
		{ "name": "Model", "value": "AN5506-04" },
		{ "name": "categoria", "value": "P" }
	],
	"validFor": {
		"startDateTime": "2026-03-11T00:00:00Z"
	}
}

### @name tmf634ResourceSpecificationPatchStatusTriggerEventV6
### Mudanca de lifecycleStatus deve gerar StatusChangeEvent
PATCH {{tmfBaseUrl}}/resourceSpecification/{{resourceSpecificationId}}
Content-Type: application/json

{
	"lifecycleStatus": "Retired"
}

### @name tmf634ResourceSpecificationPatchAttributeTriggerEventV6
### Mudanca de atributo sem alterar lifecycleStatus deve gerar AttributeValueChangeEvent
PATCH {{tmfBaseUrl}}/resourceSpecification/{{resourceSpecificationId}}
Content-Type: application/json

{
	"description": "Descricao tecnica atualizada"
}

### @name tmf634ListenerResourceSpecificationCreateV6
POST {{tmfBaseUrl}}/listener/resourceSpecificationCreateEvent
Content-Type: application/json

{
	"eventId": "evt-debug-001",
	"eventType": "ResourceSpecificationCreateEvent",
	"eventTime": "2026-03-11T00:00:00Z",
	"event": {
		"resourceSpecification": {
			"id": "spec-debug-001"
		}
	}
}

### @name tmf634ListenerResourceSpecificationAttributeValueChangeV6
POST {{tmfBaseUrl}}/listener/resourceSpecificationAttributeValueChangeEvent
Content-Type: application/json

{
	"eventId": "evt-debug-002",
	"eventType": "ResourceSpecificationAttributeValueChangeEvent",
	"eventTime": "2026-03-11T00:00:00Z",
	"event": {
		"resourceSpecification": {
			"id": "spec-debug-001"
		}
	}
}

