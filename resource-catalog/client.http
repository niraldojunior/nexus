POST {{tmfBaseUrl}}/resourceSpecification
Content-Type: application/json

{
	"name": "CPE ZTE F670L",
	"resourceCategory": [
		{
			"id": "router"
		}
	],
	"resourceSpecCharacteristic": [
		{ "name": "Brand", "value": "ZTE" },
		{ "name": "Model", "value": "F670L" },
		{ "name": "categoria", "value": "P" }
	],
	"validFor": {
		"startDateTime": "2026-03-11T00:00:00Z"
	}
}

### @name tmf634HubCreate
POST {{tmfBaseUrl}}/hub
Content-Type: application/json

{
	"callback": "http://localhost:3001/listener/tmf634"
}

