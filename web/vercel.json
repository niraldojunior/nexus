{
  "version": 2,
  "buildCommand": "vite build --config vite.config.mjs",
  "outputDirectory": "dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/health",
      "dest": "/api/server?__nexusPath=/health"
    },
    {
      "src": "/api/health",
      "dest": "/api/server?__nexusPath=/health"
    },
    {
      "src": "/api/v1/(.*)",
      "dest": "/api/server?__nexusPath=/v1/$1"
    },
    {
      "src": "/api/tmf-api/(.*)",
      "dest": "/api/server?__nexusPath=/tmf-api/$1"
    },
    {
      "src": "/v1/(.*)",
      "dest": "/api/server?__nexusPath=/v1/$1"
    },
    {
      "src": "/tmf-api/(.*)",
      "dest": "/api/server?__nexusPath=/tmf-api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
